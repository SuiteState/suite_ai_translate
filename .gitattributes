# 默认所有文本文件用 LF 行尾
* text=auto eol=lf

# 二进制文件不处理行尾
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.tar binary
*.pdf binary
*.dump binary

# Python 文件强制 LF
*.py text eol=lf

# 配置/文档文件强制 LF
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Windows 批处理保留 CRLF（这些文件本来就该是 CRLF）
*.bat text eol=crlf
*.cmd text eol=crlf