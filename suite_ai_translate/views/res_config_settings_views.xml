<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        Add Discuss AI Translate settings to the existing AI tab in
        Settings. The AI tab is created by the `ai_app` module
        (External ID: ai_app.res_config_settings_view_form), which
        injects an <app name="ai_app"> containing Provider settings.

        We inherit that view and append our own block inside the same
        <app>, so the Translation Model setting appears right below the
        Providers block on Settings -> AI.
    -->
    <record id="res_config_settings_view_form_inherit_suite_ai_translate" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.suite_ai_translate</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="ai_app.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='ai_app']" position="inside">
                <block title="Discuss AI Translate"
                       name="suite_ai_translate">
                    <setting id="sat_enabled_setting"
                             string="Enable Discuss AI Translate"
                             help="Master opt-in switch. When enabled, message text selected for translation will be transmitted to the configured AI provider (OpenAI or Google Gemini) over HTTPS. No other data is sent. Disabled by default per Odoo Apps privacy guidelines.">
                        <field name="sat_enabled"/>
                        <div class="text-muted mt-2">
                            <i class="fa fa-info-circle me-1"/>
                            By enabling this feature, you acknowledge that
                            message text selected for translation will be
                            sent to the AI provider configured above
                            (OpenAI or Google Gemini) over HTTPS. No author
                            names, attachments, or other metadata are
                            transmitted. Review the provider's terms and
                            your organization's data handling policies
                            before enabling.
                        </div>
                    </setting>
                    <setting id="sat_llm_model_setting"
                             string="Translation Model"
                             help="Primary model used by Discuss AI Translate. The 'mini' / 'flash' variants are recommended for cost-efficient conversational translation."
                             invisible="not sat_enabled">
                        <field name="sat_llm_model"/>
                        <div class="text-muted mt-2">
                            Make sure an OpenAI or Google Gemini API key
                            is enabled and set in the Providers block above
                            before using translation features.
                        </div>
                    </setting>
                    <setting id="sat_llm_failover_model_setting"
                             string="Failover Model"
                             help="Automatic fallback when the primary model's provider fails. Pick a model from a DIFFERENT provider for real resilience."
                             invisible="not sat_enabled">
                        <field name="sat_llm_failover_model"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
