<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!--
        Standalone privilege so the group appears as a checkbox in
        user settings under the Sales section.
    -->

    <record id="suite_privilege_sales_stock_visibility"
            model="res.groups.privilege">
        <field name="name">Stock Visibility</field>
        <field name="category_id"
               ref="base.module_category_sales"/>
        <field name="sequence">100</field>
    </record>

    <record id="suite_group_sales_stock_viewer" model="res.groups">
        <field name="name">Stock Viewer</field>
        <field name="privilege_id"
               ref="suite_privilege_sales_stock_visibility"/>
        <field name="comment">
            Read-only access to current on-hand quantities by location.
            Grants no inventory operation rights.
        </field>
    </record>

</odoo>
