<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Standalone stock-move history views for the Accounting Stock
        History group.

        Built from scratch to keep the Inventory app's operation
        buttons (validate, cancel, scrap, return) out of reach. The
        list / form are read-only and the form references
        move_line_ids only for inspection.
    -->

    <record id="view_suite_stock_move_search" model="ir.ui.view">
        <field name="name">suite.stock.move.search</field>
        <field name="model">stock.move</field>
        <field name="arch" type="xml">
            <search string="Stock Moves">
                <field name="product_id"/>
                <field name="reference"/>
                <field name="origin"/>
                <field name="picking_id"/>
                <field name="location_id"/>
                <field name="location_dest_id"/>
                <field name="picking_type_id"/>
                <separator/>
                <filter name="filter_done"
                        string="Done"
                        domain="[('state', '=', 'done')]"/>
                <filter name="filter_in_progress"
                        string="In Progress"
                        domain="[('state', 'in',
                                  ('draft', 'waiting', 'confirmed',
                                   'partially_available', 'assigned'))]"/>
                <filter name="filter_cancelled"
                        string="Cancelled"
                        domain="[('state', '=', 'cancel')]"/>
                <separator/>
                <filter name="filter_consigned"
                        string="Consignment Only"
                        domain="[('move_line_ids.owner_id', '!=', False)]"
                        groups="stock.group_tracking_owner"/>
                <filter name="filter_incoming"
                        string="Incoming"
                        domain="[('picking_code', '=', 'incoming')]"/>
                <filter name="filter_outgoing"
                        string="Outgoing"
                        domain="[('picking_code', '=', 'outgoing')]"/>
                <filter name="filter_internal"
                        string="Internal Transfer"
                        domain="[('picking_code', '=', 'internal')]"/>
                <separator/>
                <filter name="filter_date_today"
                        string="Today"
                        domain="[('date', '&gt;=', datetime.datetime.combine(
                                  context_today(), datetime.time(0,0,0)))]"/>
                <filter name="filter_date_30d"
                        string="Last 30 Days"
                        domain="[('date', '&gt;=', (context_today() -
                                  relativedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group>
                    <filter name="group_state"
                            string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_product"
                            string="Product"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="group_picking_type"
                            string="Operation Type"
                            context="{'group_by': 'picking_type_id'}"/>
                    <filter name="group_picking"
                            string="Transfer"
                            context="{'group_by': 'picking_id'}"/>
                    <filter name="group_date"
                            string="Date"
                            context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_suite_stock_move_list" model="ir.ui.view">
        <field name="name">suite.stock.move.list</field>
        <field name="model">stock.move</field>
        <field name="arch" type="xml">
            <list string="Consignment Moves"
                  create="false" edit="false" delete="false" duplicate="false"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancel'"
                  decoration-info="state in ('draft', 'waiting', 'confirmed',
                                              'partially_available', 'assigned')">
                <field name="date" widget="datetime"/>
                <field name="reference" optional="show"/>
                <field name="picking_id" optional="show"/>
                <field name="origin" optional="hide"/>
                <field name="product_id"/>
                <field name="product_uom_qty"
                       string="Demand" optional="hide"/>
                <field name="quantity" string="Done"/>
                <field name="product_uom" optional="hide"/>
                <field name="location_id" optional="show"/>
                <field name="location_dest_id" optional="show"/>
                <field name="picking_type_id" optional="hide"/>
                <field name="suite_owner_names" string="Owner(s)"
                       optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-muted="state == 'cancel'"
                       decoration-info="state in ('draft', 'waiting',
                                                   'confirmed',
                                                   'partially_available',
                                                   'assigned')"/>
                <field name="company_id" optional="hide"
                       groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_suite_stock_move_form" model="ir.ui.view">
        <field name="name">suite.stock.move.form</field>
        <field name="model">stock.move</field>
        <field name="arch" type="xml">
            <form string="Stock Move"
                  create="false" edit="false" delete="false" duplicate="false">
                <sheet>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="product_uom_qty"
                                   string="Demand"/>
                            <field name="quantity"
                                   string="Done"/>
                            <field name="product_uom"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="reference"/>
                            <field name="picking_id"/>
                            <field name="origin"/>
                            <field name="date"/>
                            <field name="picking_type_id"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Locations" name="locations">
                            <group>
                                <field name="location_id"/>
                                <field name="location_dest_id"/>
                            </group>
                        </page>
                        <page string="Operations" name="move_lines">
                            <field name="move_line_ids" readonly="1">
                                <list>
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="product_uom_id"/>
                                    <field name="location_id"/>
                                    <field name="location_dest_id"/>
                                    <field name="lot_id"
                                           groups="stock.group_production_lot"/>
                                    <field name="owner_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_suite_stock_move_acct_history"
            model="ir.actions.act_window">
        <field name="name">Consignment Moves</field>
        <field name="res_model">stock.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('move_line_ids.owner_id', '!=', False)]</field>
        <field name="view_ids"
               eval="[(5, 0, 0),
                      (0, 0, {'view_mode': 'list',
                              'view_id': ref('view_suite_stock_move_list')}),
                      (0, 0, {'view_mode': 'form',
                              'view_id': ref('view_suite_stock_move_form')})]"/>
        <field name="search_view_id"
               ref="view_suite_stock_move_search"/>
        <field name="context">
            {'search_default_filter_done': 1,
             'search_default_filter_date_30d': 1}
        </field>
        <field name="group_ids"
               eval="[(4, ref('suite_group_accounting_stock_history'))]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No consignment moves match the current filters.
            </p>
            <p>
                This list shows stock movements with vendor-owned
                (consigned) goods only.
            </p>
        </field>
    </record>

</odoo>
