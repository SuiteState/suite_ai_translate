<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Inventory Access tab on the user form. Always visible to
        users who can edit res.users (settings administrators); the
        field's effect only matters once the user is granted one of
        the new groups, but we surface it unconditionally to keep
        the UI predictable.
    -->
    <record id="view_users_form_suite_inventory_access" model="ir.ui.view">
        <field name="name">res.users.form.suite.inventory.access</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Inventory Access"
                      name="suite_inventory_access">
                    <group>
                        <field name="suite_accessible_location_ids"
                               widget="many2many_tags"
                               options="{'no_create': True}"/>
                    </group>
                    <p class="text-muted">
                        Restricts the locations visible in the Sales
                        Stock Viewer and Accounting Stock History
                        menus. Empty = no restriction. Selecting a
                        parent location includes all of its child
                        locations automatically.
                    </p>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
