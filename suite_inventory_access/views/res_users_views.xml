<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_users_form_suite_inventory_access" model="ir.ui.view">
        <field name="name">res.users.form.suite.inventory.access</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Stock View Access"
                      name="suite_inventory_access">
                    <group>
                        <field name="suite_accessible_location_ids"
                               widget="many2many_tags"
                               options="{'no_create': True}"/>
                    </group>
                    <p class="text-muted">
                        Restricts the locations visible in the Sales
                        Stock Viewer menu. Empty = no restriction.
                        Selecting a parent location includes all of
                        its child locations automatically.
                    </p>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
