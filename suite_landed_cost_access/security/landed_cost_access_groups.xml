<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!--
        Standalone privilege so the group appears as a checkbox
        in user settings under the Accounting section.
    -->

    <record id="suite_privilege_landed_cost"
            model="res.groups.privilege">
        <field name="name">Landed Costs</field>
        <field name="category_id"
               ref="base.module_category_accounting"/>
        <field name="sequence">110</field>
    </record>

    <record id="suite_group_landed_cost_user" model="res.groups">
        <field name="name">Landed Cost User</field>
        <field name="privilege_id"
               ref="suite_privilege_landed_cost"/>
        <field name="implied_ids"
               eval="[(4, ref('account.group_account_invoice'))]"/>
        <field name="comment">
            Full access to landed cost records (create, validate,
            cancel). Implies Invoicing rights (journal entries).
            Also grants read/write access to stock pickings, moves,
            locations, and lots as needed by the landed cost
            validation workflow. Does not grant any Inventory
            operational or configuration rights.
        </field>
    </record>

</odoo>
