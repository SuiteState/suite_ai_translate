<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search view -->
    <record id="view_suite_consignment_cogs_line_search" model="ir.ui.view">
        <field name="name">suite.consignment.cogs.line.search</field>
        <field name="model">suite.consignment.cogs.line</field>
        <field name="arch" type="xml">
            <search string="Consignment Settlement Lines">
                <field name="name"/>
                <field name="invoice_id"/>
                <field name="bill_id"/>
                <field name="owner_id"/>
                <field name="product_id"/>
                <field name="sale_order_id"/>
                <separator/>
                <filter name="filter_pending"
                        string="Pending Settlement"
                        domain="[('state', '=', 'pending')]"/>
                <filter name="filter_settled"
                        string="Settled"
                        domain="[('state', '=', 'settled')]"/>
                <filter name="filter_cancelled"
                        string="Cancelled"
                        domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <group>
                    <filter name="group_owner"
                            string="Owner / Vendor"
                            context="{'group_by': 'owner_id'}"/>
                    <filter name="group_state"
                            string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_product"
                            string="Product"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="group_invoice"
                            string="Invoice"
                            context="{'group_by': 'invoice_id'}"/>
                    <filter name="group_bill"
                            string="Vendor Bill"
                            context="{'group_by': 'bill_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- List view -->
    <record id="view_suite_consignment_cogs_line_list" model="ir.ui.view">
        <field name="name">suite.consignment.cogs.line.list</field>
        <field name="model">suite.consignment.cogs.line</field>
        <field name="arch" type="xml">
            <list string="Consignment Settlement Lines"
                  decoration-warning="state == 'pending'"
                  decoration-success="state == 'settled'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="invoice_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="owner_id"/>
                <field name="sales_unit_price" optional="hide"/>
                <field name="sales_subtotal" optional="hide"/>
                <field name="product_cost"/>
                <field name="cost_subtotal"/>
                <field name="bill_id"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'pending'"
                       decoration-success="state == 'settled'"
                       decoration-muted="state == 'cancelled'"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="company_id" column_invisible="1"
                       groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_suite_consignment_cogs_line_form" model="ir.ui.view">
        <field name="name">suite.consignment.cogs.line.form</field>
        <field name="model">suite.consignment.cogs.line</field>
        <field name="arch" type="xml">
            <form string="Consignment Settlement Line">
                <header>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,pending,settled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Sale">
                            <field name="invoice_id"/>
                            <field name="invoice_line_id" invisible="1"/>
                            <field name="sale_order_id"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="owner_id"/>
                            <field name="sales_unit_price"
                                   widget="monetary"/>
                            <field name="sales_subtotal"
                                   widget="monetary"/>
                        </group>
                        <group string="Settlement">
                            <field name="bill_id"
                                   options="{'no_create': True}"/>
                            <field name="product_cost"/>
                            <field name="cost_subtotal"
                                   widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_suite_consignment_cogs_line"
            model="ir.actions.act_window">
        <field name="name">Consignment Settlement</field>
        <field name="res_model">suite.consignment.cogs.line</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id"
               ref="view_suite_consignment_cogs_line_search"/>
        <field name="context">{'search_default_filter_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No consignment COGS lines yet.
            </p>
            <p>
                Lines are generated automatically when a customer invoice
                is posted that contains products delivered from
                vendor-consigned stock (stock with a non-empty owner).
            </p>
        </field>
    </record>

</odoo>
